# .gitignore

# Local SDK
.sdk/

# IDE / Editor folders and files
.vscode/
.idea/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/
.nbproject/

# Java/Maven Build Outputs
portfolio-backend/target/
portfolio-backend/*.log
portfolio-backend/dependency-reduced-pom.xml

# Node/Next.js Build Outputs & Dependencies
portfolio-frontend/node_modules/
portfolio-frontend/.next/
portfolio-frontend/out/
portfolio-frontend/build/
portfolio-frontend/.next-env.d.ts
portfolio-frontend/npm-debug.log*
portfolio-frontend/yarn-debug.log*
portfolio-frontend/yarn-error.log*

# Environment and Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local

# OS system files
Thumbs.db
desktop.ini
.DS_Store
